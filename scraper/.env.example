# Copia este archivo como  .env  y rellena tus valores reales.
# El archivo .env NO debe subirse a ningún sitio público (contiene contraseñas).

# --- Mi Vodafone Business ---
VODAFONE_USER=tu_usuario
VODAFONE_PASS=tu_contraseña

# --- 2FA: buzón IONOS que recibe el código de verificación ---
IMAP_HOST=imap.ionos.es
IMAP_PORT=993
IMAP_USER=jeremy@avenuemedia.io
IMAP_PASS=contraseña_del_buzon
# (opcional) si conoces el remitente exacto del correo de Vodafone, ponlo aquí
OTP_SENDER=
# (opcional) regex del código; por defecto 4-8 dígitos
OTP_REGEX=\b(\d{4,8})\b
# segundos máximos esperando el correo con el código
OTP_TIMEOUT=120
# segundos de espera inicial antes de la primera consulta del buzón
OTP_INITIAL_WAIT=6
# segundos entre reintentos de consulta del buzón
OTP_POLL_INTERVAL=5

# --- Datos de la cuenta a consultar (valores fijos del flujo) ---
TARGET_CIF=B47573944
TARGET_ACCOUNT=29250841

# --- Supabase (proyecto "vodafone scrape") ---
# Supabase -> Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Opciones ---
# true = navegador invisible (producción). false = visible (para depurar).
HEADLESS=true
# reutilizar la sesión guardada para intentar saltar el 2FA en ejecuciones siguientes
USE_SAVED_SESSION=true
